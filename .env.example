# Gemini proxy runtime
GEMINI_API_KEY=your_server_side_gemini_key
GEMINI_ALLOWED_MODELS=gemini-1.5-pro-latest
GEMINI_TIMEOUT_SECONDS=30
REQUEST_BODY_LIMIT_BYTES=1048576
RATE_LIMIT_PER_MINUTE=30

# Comma-separated local dev origins for browser clients
CORS_ALLOWLIST=http://localhost:8501,http://127.0.0.1:8501,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Streamlit frontend uses this to call the backend proxy
GEMINI_PROXY_BASE_URL=http://localhost:8000
GEMINI_PROXY_MODEL=gemini-1.5-pro-latest
GEMINI_PROXY_TIMEOUT_SECONDS=30

# Optional for OpenAI-based feedback path
OPENAI_API_KEY=your_openai_key_optional
